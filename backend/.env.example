# PetroVision — Environment Variables (Development)
# Copy to .env and adjust for your environment

# App
APP_NAME=PetroVision
DEBUG=true
SECRET_KEY=petrovision-secret-key-change-in-production-2026

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=petrovision
POSTGRES_PASSWORD=petrovision2026
POSTGRES_DB=petrovision

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=petrovision-influx-token-2026
INFLUXDB_ORG=petrovision
INFLUXDB_BUCKET=process_data

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Simulation
SIMULATION_ENABLED=true
SIMULATION_INTERVAL_SECONDS=2.0
